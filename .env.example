# Optional: canonical site URL for Supabase redirect allow-list (must match URLs you add in Dashboard → Auth → URL Configuration)
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Supabase (get from Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase project ref (used by scripts/by-branch.js for branch-aware linking)
# Example: lmevpzxbwojrzfxtxxgy
SUPABASE_PROJECT_REF=your-project-ref

# Required for correct role-based access (server-only, never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: secret for GET /api/db-keepalive?token=... (recommended in production for cron-job.org)
# CRON_KEEPALIVE_SECRET=long-random-string

# Optional: Welcome page weather (Open-Meteo). Defaults to India centroid if unset.
# NEXT_PUBLIC_WEATHER_LAT=19.0760
# NEXT_PUBLIC_WEATHER_LON=72.8777

# Optional: used by scripts/clone-prod-to-dev.js (npm run clone:prod-to-dev)
# SUPABASE_DB_PASSWORD_DEVELOPMENT=your-dev-db-password
